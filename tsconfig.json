{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".", // 追加：パス解決の基準点を明確にします
    "paths": {
      "@/*": ["./src/*"] // 修正：./* から ./src/* に変更
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "src/components/sound/Sound.tsx", // 修正：拡張子が .tx になっていたのを .tsx に
    "next.config.mjs",
    "messages/**/*.json" // 追加：翻訳ファイルの型補完のため
  ],
  "exclude": ["node_modules"]
}
